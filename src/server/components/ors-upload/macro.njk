{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% macro orsUpload(params) %}
  <form
    class="form"
    action="{{ params.uploadUrl }}"
    method="post"
    enctype="multipart/form-data"
  >
    {{ govukFileUpload({
      id: "ors-upload",
      name: "orsUpload",
      label: {
        text: params.fileUploadLabel,
        classes: "govuk-!-font-weight-bold govuk-!-margin-bottom-4"
      },
      formGroup: {
        classes: "govuk-!-margin-top-4"
      },
      javascript: true,
      attributes: {
        accept: ".xlsx,.xlsm",
        multiple: true,
        required: true
      }
    }) }}

    <div class="govuk-button-group">
      {{ govukButton({
        text: params.buttonText,
        preventDoubleClick: true
      }) }}
    </div>
  </form>
{% endmacro %}
