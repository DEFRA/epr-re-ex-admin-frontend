{% extends 'layout.njk' %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  <div class="govuk-width-container">
    <h1 class="govuk-heading-xl">{{ heading }}</h1>

    {% if grantResult and grantResult.status === 'success' %}
      {{ govukNotificationBanner({ type: 'success', text: 'Registration approved' }) }}
    {% endif %}

    {% set statusActions = [] %}
    {% if registration.status === 'created' and SCOPES.adminWrite in scopes %}
      {% set approveUrl = '/organisations/' ~ organisationId ~ '/registrations/' ~ registrationId ~ '/approve/confirm' %}
      {% set statusActions = [{ href: approveUrl, text: "Approve", visuallyHiddenText: "registration" }] %}
    {% endif %}

    {% set summaryRows = [
      { key: { text: "Status" }, value: { html: govukTag({ text: registration.status }) }, actions: { items: statusActions } },
      { key: { text: "Processing type" }, value: { text: registration.processingType } },
      { key: { text: "Material" }, value: { text: registration.material } },
      { key: { text: "Site" }, value: { text: registration.site } }
    ] %}
    {% if registration.registrationNumber %}
      {% set summaryRows = [{ key: { text: "Registration number" }, value: { text: registration.registrationNumber } }].concat(summaryRows) %}
    {% endif %}
    {% if registration.accreditation %}
      {% set summaryRows = summaryRows.concat([
        { key: { text: "Accreditation number" }, value: { text: registration.accreditation.accreditationNumber } },
        { key: { text: "Accreditation status" }, value: { html: govukTag({ text: registration.accreditation.status }) } },
        { key: { text: "Waste balance (tonnes)" }, value: { text: wasteBalance.amount if wasteBalance else "No data" } },
        { key: { text: "Waste balance available (tonnes)" }, value: { text: wasteBalance.availableAmount if wasteBalance else "No data" } },
        { key: { text: "Waste balance events" }, value: { html: '<a class="govuk-link govuk-link--no-visited-state" href="' ~ wasteBalanceEventsUrl ~ '">View</a>' } }
      ]) %}
      {% if overseasSitesUrl %}
        {% set summaryRows = summaryRows.concat([
          { key: { text: "Overseas sites" }, value: { html: '<a class="govuk-link govuk-link--no-visited-state" href="' ~ overseasSitesUrl ~ '">View</a>' } }
        ]) %}
      {% endif %}
    {% endif %}

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        {{ govukSummaryList({ rows: summaryRows }) }}
      </div>
    </div>
    <div class="govuk-grid-row">
      <div id="reports" class="govuk-grid-column-two-thirds">
        {% if reportingPeriods and reportingPeriods.length %}
          {% set tableRows = [] %}
          {% for period in reportingPeriods %}
            {% set statusText = period.report.status if period.report else 'Due' %}
            {% if period.report %}
              {% set reportUrl = '/organisations/' ~ organisationId ~ '/registrations/' ~ registrationId ~ '/reports/' ~ period.year ~ '/' ~ cadence ~ '/' ~ period.period ~ '/submissions/' ~ period.submissionNumber %}
            {% endif %}
            {% set actionsHtml %}
              {% if period.report %}
                <a class="govuk-link govuk-link--no-visited-state" href="{{ reportUrl }}">View</a>
              {% endif %}
              {% if period.report and period.report.status === 'submitted' and SCOPES.adminWrite in scopes %}
                {% set unsubmitUrl = '/organisations/' ~ organisationId ~ '/registrations/' ~ registrationId ~ '/reports/' ~ period.year ~ '/' ~ cadence ~ '/' ~ period.period ~ '/submissions/' ~ period.submissionNumber ~ '/unsubmit/confirm' %}
                <br><a class="govuk-link govuk-link--no-visited-state" href="{{ unsubmitUrl }}">Unsubmit</a>
              {% endif %}
            {% endset %}
            {% set row = [
              { text: period.formattedPeriod },
              { text: period.dueDate },
              { html: govukTag({ text: statusText }) },
              { html: actionsHtml }
            ] %}
            {% set tableRows = tableRows.concat([row]) %}
          {% endfor %}

          {{ govukTable({
            caption: "Reports",
            captionClasses: "govuk-table__caption--m",
            head: [
              { text: "Period" },
              { text: "Due" },
              { text: "Status" },
              { text: "Actions" }
            ],
            rows: tableRows
          }) }}
        {% endif %}
      </div>
    </div>
    <div class="govuk-grid-row">
      <div id="summary-logs" class="govuk-grid-column-two-thirds">
        {% if summaryLogRows and summaryLogRows.length %}
          {{ govukTable({
            caption: "Summary logs",
            captionClasses: "govuk-table__caption--m",
            head: [
              { text: "Uploaded at" },
              { text: "Status" },
              { text: "Actions" }
            ],
            rows: summaryLogRows
          }) }}
        {% else %}
          <p class="govuk-body">No summary logs</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
