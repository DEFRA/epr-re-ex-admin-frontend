{% extends 'layout.njk' %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="app-page-body">

        {% if error %}
          {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [
              {
                text: error
              }
            ]
          }) }}
        {% endif %}

        <h1 class="govuk-heading-xl">{{ pageTitle }}</h1>

        <p class="govuk-body">
          Cumulative total of incoming tonnage, excluding any PRN or sent-on deductions. Includes all uploaded records regardless of accreditation dates.
        </p>

        <p class="govuk-body">
          Data generated at: <strong>{{ generatedAt | formatDate("d MMMM yyyy 'at' h:mmaaa") }}</strong>
        </p>

        <p class="govuk-body">
                   Grand total (all records): <strong>{{ total }}</strong>
        </p>

        {% if materials and materials.length %}
          {% set tableHead = [] %}
          {% set tableHead = tableHead.concat([{ text: "Material" }]) %}
          {% set tableHead = tableHead.concat([{ text: "Type" }]) %}
          {% if hasMultipleYears %}
            {% set tableHead = tableHead.concat([{ text: "Year" }]) %}
          {% endif %}
          {% for monthName in monthNames %}
            {% set tableHead = tableHead.concat([{ text: monthName, format: "numeric" }]) %}
          {% endfor %}

          {% set tableRows = [] %}
          {% for item in materials %}
            {% set row = [] %}
            {% set row = row.concat([{ text: item.material }]) %}
            {% set row = row.concat([{ text: item.type }]) %}
            {% if hasMultipleYears %}
              {% set row = row.concat([{ text: item.year }]) %}
            {% endif %}
            {% for monthName in monthNames %}
              {% set row = row.concat([{ text: item[monthName], format: "numeric" }]) %}
            {% endfor %}
            {% set tableRows = tableRows.concat([row]) %}
          {% endfor %}

          {{ govukTable({
            caption: "Tonnage by material and type" + (" per year" if hasMultipleYears else "") + " with monthly breakdown",
            captionClasses: "govuk-visually-hidden",
            firstCellIsHeader: true,
            head: tableHead,
            rows: tableRows
          }) }}

          <form method="POST">
            <input type="hidden" name="crumb" value="{{ crumb }}" />
            {{ govukButton({
              text: "Download CSV"
            }) }}
          </form>

        {% else %}
          {{ govukInsetText({ text: "No tonnage data available." }) }}
        {% endif %}

      </div>
    </div>
  </div>
{% endblock %}
