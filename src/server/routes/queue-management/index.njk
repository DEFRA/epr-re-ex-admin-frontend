{% extends 'layout.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <div class="govuk-body" data-testid="app-page-body">

        {% if success %}
          {% set successHtml %}
            <p class="govuk-body">All dead-letter queue messages have been cleared.</p>
          {% endset %}

          {{ govukNotificationBanner({
            html: successHtml,
            type: "success"
          }) }}
        {% endif %}

        <h1 class="govuk-heading-xl">{{ heading }}</h1>

        <p class="govuk-body">
          The dead-letter queue currently has
          <strong>{{ approximateMessageCount }}</strong>
          {{ "message" if approximateMessageCount === 1 else "messages" }}.
        </p>

        {% if messages and messages.length %}
          {% set tableRows = [] %}
          {% for msg in messages %}
            {% set bodyHtml %}
              {{ govukDetails({
                summaryText: "Show raw message",
                html: '<code class="app-json-display">' ~ (msg.bodyJson | escape) ~ '</code>'
              }) }}
            {% endset %}

            {% set tableRows = tableRows.concat([[
              { text: msg.commandType },
              { text: msg.sentTimestamp },
              { text: msg.receiveCount },
              { html: bodyHtml }
            ]]) %}
          {% endfor %}

          {{ govukTable({
            firstCellIsHeader: false,
            head: [
              { text: "Command type" },
              { text: "Sent timestamp" },
              { text: "Receive count" },
              { text: "Raw message" }
            ],
            rows: tableRows
          }) }}

          {{ govukButton({
            text: "Clear all messages",
            href: "/queue-management/confirm-clear",
            classes: "govuk-button--warning"
          }) }}
        {% else %}
          <p class="govuk-body">There are no messages on the dead-letter queue.</p>
        {% endif %}

      </div>
    </div>
  </div>
{% endblock %}
