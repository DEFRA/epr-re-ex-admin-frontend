{
  "extends": "./jsconfig.typecheck.base.json",
  "compilerOptions": {
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"],
    "useUnknownInCatchVariables": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "**/*.test.js",
    "**/test-helpers/**/*.js",
    "**/test-fixtures.js"
  ],
  "exclude": ["node_modules", ".vite"]
}
